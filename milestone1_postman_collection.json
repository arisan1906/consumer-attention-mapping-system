						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test_admin@store.com\",\n    \"password\": \"Password123!\",\n    \"role\": \"Admin\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
