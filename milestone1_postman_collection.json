							"raw": "{\n    \"zones\": [\n        {\n            \"name\": \"Produce & Bakery\",\n            \"x_min\": 0.0,\n            \"y_min\": 0.0,\n            \"x_max\": 8.5,\n            \"y_max\": 12.0\n        },\n        {\n            \"name\": \"Dairy Section\",\n            \"x_min\": 8.5,\n            \"y_min\": 0.0,\n            \"x_max\": 16.0,\n            \"y_max\": 12.0\n        }\n    ],\n    \"shelves\": [\n        {\n            \"zone_name\": \"Produce & Bakery\",\n            \"name\": \"Apple Shelving Rack A\",\n            \"x_min\": 1.0,\n            \"y_min\": 2.0,\n            \"x_max\": 6.0,\n            \"y_max\": 3.5,\n            \"layers\": 4\n        },\n        {\n            \"zone_name\": \"Dairy Section\",\n            \"name\": \"Milk Cooler Display C\",\n            \"x_min\": 9.0,\n            \"y_min\": 1.0,\n            \"x_max\": 14.5,\n            \"y_max\": 2.8,\n            \"layers\": 3\n        }\n    ]\n}"
